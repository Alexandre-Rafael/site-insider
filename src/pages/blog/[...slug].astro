---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const SITE = 'https://insider-khaki.vercel.app';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

interface Props { post: CollectionEntry<'blog'> }
const { post } = Astro.props;
const { Content } = await post.render();

const fmt = (d: Date) => d.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });

const description = post.data.excerpt ?? post.data.subtitle ?? post.data.title;
const ogImage = post.data.cover.startsWith('http') ? post.data.cover : `${SITE}${post.data.cover}`;
const canonicalURL = `${SITE}/blog/${post.slug}/`;
const linkedinURL = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalURL)}`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: description,
  image: ogImage,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  author: { '@type': 'Organization', name: post.data.author, url: SITE },
  publisher: {
    '@type': 'Organization',
    name: 'Insider Mídia',
    logo: { '@type': 'ImageObject', url: `${SITE}/assets/INSIDER%20-%20logo%20branca.png` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL },
});
---
<BaseLayout
  title={`${post.data.title} | Insider Mídia`}
  current="blog"
  description={description}
  cover={post.data.cover}
  type="article"
  publishedTime={post.data.date.toISOString()}
  articleAuthor={post.data.author}
  articleSection={post.data.category}
>
  <script type="application/ld+json" set:html={jsonLd} slot="head" />

  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-0">

    <!-- Breadcrumb + Categoria -->
    <div class="flex items-center gap-3 mb-6">
      <a href="/blog/" class="inline-flex items-center gap-1.5 text-slate-400 hover:text-white text-sm transition-colors">
        <span class="material-symbols-outlined text-base">arrow_back</span>
        Voltar para o blog
      </a>
      <span class="text-slate-600">·</span>
      <span class="inline-block bg-primary/20 text-primary-light text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full">{post.data.category}</span>
    </div>

    <!-- Título e subtítulo -->
    <div class="max-w-3xl mb-6">
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-4">{post.data.title}</h1>
      {post.data.subtitle && <p class="text-xl text-slate-300">{post.data.subtitle}</p>}
    </div>

    <!-- Imagem de capa -->
    <div class="w-full aspect-[21/8] rounded-2xl overflow-hidden mb-6 bg-surface-dark">
      <img src={post.data.cover} alt={post.data.title} class="w-full h-full object-cover" />
    </div>

    <!-- Barra: data + compartilhar -->
    <div class="flex items-center justify-between py-4 mb-10 border-b border-white/10">
      <div>
        <p class="text-xs text-slate-500 uppercase tracking-widest mb-0.5">Publicado em</p>
        <p class="text-sm font-medium text-slate-300">{fmt(post.data.date)}</p>
      </div>
      <div class="flex items-center gap-2">
        <button
          id="copy-btn"
          title="Copiar link"
          class="share-btn flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium border border-white/10 bg-white/5 hover:bg-white/10 transition-colors"
        >
          <span class="material-symbols-outlined text-base">link</span>
          <span id="copy-label">Copiar link</span>
        </button>
        <a
          href={linkedinURL}
          target="_blank"
          rel="noopener noreferrer"
          title="Compartilhar no LinkedIn"
          class="share-btn flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium border border-white/10 bg-white/5 hover:bg-[#0A66C2]/20 hover:border-[#0A66C2]/50 transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>

    <!-- Grid: conteúdo + sidebar -->
    <div class="grid lg:grid-cols-[1fr_240px] gap-12 items-start pb-0">

      <!-- Conteúdo principal -->
      <div class="prose-insider min-w-0">
        <Content />
      </div>

      <!-- Sidebar sticky -->
      <aside class="hidden lg:block">
        <div class="sticky top-28 space-y-6">

          <!-- Índice -->
          <div class="glass-card rounded-xl p-5">
            <p class="text-xs font-bold uppercase tracking-widest text-primary mb-4">Índice</p>
            <nav id="toc" class="space-y-1 text-sm"></nav>
          </div>

          <!-- Compartilhar (sidebar) -->
          <div class="glass-card rounded-xl p-5">
            <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-3">Compartilhar</p>
            <div class="flex flex-col gap-2">
              <button
                id="copy-btn-sidebar"
                class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-slate-300 hover:text-white hover:bg-white/5 transition-colors text-left"
              >
                <span class="material-symbols-outlined text-base">link</span>
                <span id="copy-label-sidebar">Copiar link</span>
              </button>
              <a
                href={linkedinURL}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-slate-300 hover:text-white hover:bg-[#0A66C2]/20 transition-colors"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
                </svg>
                Compartilhar no LinkedIn
              </a>
            </div>
          </div>

        </div>
      </aside>
    </div>

    <!-- CTA -->
    <div class="mt-20 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-16 text-center" style="background: radial-gradient(ellipse at 50% 0%, rgba(59,130,246,0.18) 0%, transparent 70%), linear-gradient(180deg, #0d1220 0%, #0B0F19 100%); border-top: 1px solid rgba(59,130,246,0.2);">
      <div class="text-4xl mb-6">🚀</div>
      <h3 class="text-3xl md:text-4xl font-bold mb-4 leading-tight">
        Pronto para <span class="text-white">transformar</span> os<br class="hidden md:block" /> resultados <span class="text-primary-light">do seu negócio?</span>
      </h3>
      <p class="text-slate-400 mb-8 text-lg max-w-md mx-auto">Fale agora com um especialista da Insider Mídia.</p>
      <a href="/contato/" class="inline-flex items-center gap-3 px-8 py-4 text-base font-bold rounded-full text-white bg-gradient-to-r from-primary to-primary-dark hover:from-primary-light hover:to-primary shadow-xl shadow-primary/40 glow-effect transition-all hover:scale-105">
        Falar com um Especialista Agora
        <span style="font-size:1.1rem;">→</span>
      </a>
    </div>

  </article>
</BaseLayout>

<style>
  #toc a {
    display: block;
    padding: 0.3rem 0.5rem;
    border-radius: 6px;
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
    line-height: 1.4;
  }
  #toc a:hover, #toc a.active {
    color: #fff;
    background: rgba(59,130,246,0.12);
  }
  #toc a.toc-h3 {
    padding-left: 1.1rem;
    font-size: 0.8rem;
    color: #64748b;
  }
  #toc a.toc-h3:hover { color: #cbd5e1; }
</style>

<script is:inline>
  // Gera índice lateral
  const prose = document.querySelector('.prose-insider');
  const toc = document.getElementById('toc');
  if (prose && toc) {
    const headings = prose.querySelectorAll('h2, h3');
    if (headings.length > 0) {
      headings.forEach((h, i) => {
        if (!h.id) h.id = 'sec-' + i;
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent;
        a.className = h.tagName === 'H3' ? 'toc-h3' : '';
        toc.appendChild(a);
      });
    } else {
      toc.closest('.glass-card').style.display = 'none';
    }
  }

  // Destaca seção ativa no scroll
  const tocLinks = document.querySelectorAll('#toc a');
  if (tocLinks.length) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        const link = document.querySelector('#toc a[href="#' + e.target.id + '"]');
        if (link) link.classList.toggle('active', e.isIntersecting);
      });
    }, { rootMargin: '-20% 0px -70% 0px' });
    document.querySelectorAll('.prose-insider h2, .prose-insider h3').forEach(h => observer.observe(h));
  }

  // Copiar link
  function copyLink(labelId) {
    navigator.clipboard.writeText(window.location.href).then(() => {
      const label = document.getElementById(labelId);
      if (label) {
        label.textContent = 'Copiado!';
        setTimeout(() => label.textContent = 'Copiar link', 2000);
      }
    });
  }
  const copyBtn = document.getElementById('copy-btn');
  const copyBtnSidebar = document.getElementById('copy-btn-sidebar');
  if (copyBtn) copyBtn.addEventListener('click', () => copyLink('copy-label'));
  if (copyBtnSidebar) copyBtnSidebar.addEventListener('click', () => copyLink('copy-label-sidebar'));
</script>
