---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categorias = [...new Set(posts.map(p => p.data.category))].sort();

const featured = posts[0];
const rest = posts.slice(1);

const fmt = (d: Date) => d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
---
<BaseLayout title="Blog | Insider Mídia" current="blog" description="Insights, cases e bastidores da Insider Mídia.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8">
    <div class="text-center mb-12">
      <p class="text-primary text-sm font-semibold uppercase tracking-wider mb-3">Insider Insights</p>
      <h1 class="text-4xl md:text-6xl font-bold mb-4">Blog</h1>
      <p class="text-slate-400 max-w-2xl mx-auto">Cases reais, estratégias que funcionam e os bastidores de quem transforma visitantes em clientes.</p>
    </div>

    {categorias.length > 0 && (
      <div class="flex flex-wrap justify-center gap-2 mb-12" id="filtros">
        <button data-cat="all" class="filtro-btn px-4 py-2 rounded-full text-sm font-medium border border-white/10 bg-white/5 hover:bg-primary/20 hover:border-primary transition-colors active-filter">Todos</button>
        {categorias.map((c) => (
          <button data-cat={c} class="filtro-btn px-4 py-2 rounded-full text-sm font-medium border border-white/10 bg-white/5 hover:bg-primary/20 hover:border-primary transition-colors">{c}</button>
        ))}
      </div>
    )}

    {featured && (
      <a href={`/blog/${featured.slug}/`} data-cat={featured.data.category} class="post-card group block mb-16">
        <div class="grid md:grid-cols-2 gap-8 glass-card p-6 md:p-8 rounded-2xl hover:border-primary/40 transition-all">
          <div class="aspect-video md:aspect-auto rounded-xl overflow-hidden bg-surface-dark">
            <img src={featured.data.cover} alt={featured.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="flex flex-col justify-center">
            <span class="text-primary text-xs font-semibold uppercase tracking-wider mb-3">{featured.data.category}</span>
            <h2 class="text-2xl md:text-3xl font-bold mb-3 group-hover:text-primary-light transition-colors">{featured.data.title}</h2>
            {featured.data.subtitle && <p class="text-slate-400 mb-4">{featured.data.subtitle}</p>}
            <div class="text-sm text-slate-500">{featured.data.author} · {fmt(featured.data.date)}</div>
          </div>
        </div>
      </a>
    )}

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" id="lista">
      {rest.map((p) => (
        <a href={`/blog/${p.slug}/`} data-cat={p.data.category} class="post-card group block glass-card rounded-2xl overflow-hidden hover:border-primary/40 transition-all">
          <div class="aspect-video bg-surface-dark overflow-hidden">
            <img src={p.data.cover} alt={p.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-6">
            <span class="text-primary text-xs font-semibold uppercase tracking-wider">{p.data.category}</span>
            <h3 class="text-lg font-bold mt-2 mb-2 group-hover:text-primary-light transition-colors">{p.data.title}</h3>
            {p.data.subtitle && <p class="text-slate-400 text-sm mb-3 line-clamp-2">{p.data.subtitle}</p>}
            <div class="text-xs text-slate-500">{fmt(p.data.date)}</div>
          </div>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="text-center text-slate-400 py-16">Em breve, nossas primeiras matérias.</p>
    )}
  </section>

  <style>
    .active-filter { background: rgba(59, 130, 246, 0.2); border-color: #3B82F6; color: #fff; }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  </style>

  <script is:inline>
    const botoes = document.querySelectorAll('.filtro-btn');
    const cards = document.querySelectorAll('.post-card');
    botoes.forEach((b) => {
      b.addEventListener('click', () => {
        botoes.forEach((x) => x.classList.remove('active-filter'));
        b.classList.add('active-filter');
        const cat = b.getAttribute('data-cat');
        cards.forEach((c) => {
          const match = cat === 'all' || c.getAttribute('data-cat') === cat;
          c.style.display = match ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
