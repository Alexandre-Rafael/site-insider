---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categorias = [...new Set(posts.map(p => p.data.category))].sort();

const fmt = (d: Date) => d.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });

const featured  = posts[0];
const sideCards = posts.slice(1, 5);
const rest      = posts.slice(5);
---
<BaseLayout title="Blog | Insider Mídia" current="blog" description="Insights, cases e bastidores da Insider Mídia.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-20">

    <!-- Cabeçalho -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-4">
      <div>
        <p class="text-primary text-sm font-semibold uppercase tracking-wider mb-3">Insider Insights</p>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Blog</h1>
        <p class="text-slate-400 max-w-xl text-base">Cases reais, estratégias que funcionam e os bastidores de quem transforma visitantes em clientes.</p>
      </div>
      {categorias.length > 0 && (
        <div class="shrink-0">
          <div class="select-wrapper">
            <select id="filtro-cat">
              <option value="all">Filtrar por assunto</option>
              {categorias.map((c) => <option value={c}>{c}</option>)}
            </select>
            <span class="select-arrow">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </div>
      )}
    </div>

    <div class="border-t border-white/10 mb-8"></div>

    {posts.length === 0 && (
      <p class="text-center text-slate-400 py-20">Em breve, nossas primeiras matérias.</p>
    )}

    {posts.length > 0 && (
      <div id="container-posts">

        <!-- BLOCO 1: destaque (row-span-2) + 2×2 ao lado -->
        {featured && (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4 items-stretch" id="bloco-destaque">

            <!-- Card destaque grande -->
            <a
              href={`/blog/${featured.slug}/`}
              data-cat={featured.data.category}
              class="post-card group md:row-span-2 flex flex-col glass-card rounded-xl overflow-hidden hover:border-primary/30 transition-colors duration-300"
              style="min-height: 380px;"
            >
              <div class="p-6 flex flex-col flex-1 relative z-10">
                {featured.data.logo
                  ? <img src={featured.data.logo} alt="logo" class="h-7 w-auto object-contain mb-4 opacity-90" />
                  : <span class="text-primary text-xs font-semibold uppercase tracking-widest mb-4 block">{featured.data.category}</span>
                }
                <h2 class="text-xl md:text-2xl font-bold leading-snug group-hover:text-primary-light transition-colors">{featured.data.title}</h2>
                <p class="card-date text-xs text-slate-500 mt-5 pt-4 border-t border-white/10">{fmt(featured.data.date)}</p>
              </div>
              <div class="overflow-hidden shrink-0" style="height: 220px;">
                <img
                  src={featured.data.cover}
                  alt={featured.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  style={`object-position: ${featured.data.coverPosition ?? 'center'}`}
                />
              </div>
            </a>

            <!-- 4 cards pequenos com fade in da imagem -->
            {sideCards.map((p) => (
              <a
                href={`/blog/${p.slug}/`}
                data-cat={p.data.category}
                class="post-card group relative flex flex-col glass-card rounded-xl overflow-hidden hover:border-primary/30 transition-colors duration-300"
                style="min-height: 240px;"
              >
                <!-- Texto -->
                <div class="p-5 flex flex-col flex-1 relative z-10">
                  {p.data.logo
                    ? <img src={p.data.logo} alt="logo" class="h-6 w-auto object-contain mb-3 opacity-90" />
                    : <span class="text-primary text-xs font-semibold uppercase tracking-widest mb-3 block">{p.data.category}</span>
                  }
                  <h3 class="text-sm font-bold leading-snug flex-1 group-hover:text-white transition-colors">{p.data.title}</h3>
                  <p class="card-date text-xs text-slate-500 mt-4 pt-3 border-t border-white/10">{fmt(p.data.date)}</p>
                </div>
                <!-- Seta -->
                <div class="card-arrow absolute bottom-4 right-4 z-20 w-8 h-8 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center">
                  <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                    <path d="M2 12L12 2M12 2H5M12 2V9" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <!-- Imagem com fade in -->
                <div class="card-img absolute bottom-0 left-0 right-0" style="height: 60%;">
                  <div class="card-img-fade"></div>
                  <img
                    src={p.data.cover}
                    alt={p.data.title}
                    class="w-full h-full object-cover"
                    style={`object-position: ${p.data.coverPosition ?? 'center'}`}
                  />
                </div>
              </a>
            ))}
          </div>
        )}

        <!-- BLOCO 2: grid 3 colunas -->
        {rest.length > 0 && (
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" id="lista">
            {rest.map((p) => (
              <a
                href={`/blog/${p.slug}/`}
                data-cat={p.data.category}
                class="post-card group relative flex flex-col glass-card rounded-xl overflow-hidden hover:border-primary/30 transition-colors duration-300"
                style="min-height: 220px;"
              >
                <div class="p-5 flex flex-col flex-1 relative z-10">
                  {p.data.logo
                    ? <img src={p.data.logo} alt="logo" class="h-5 w-auto object-contain mb-3 opacity-90" />
                    : <span class="text-primary text-xs font-semibold uppercase tracking-widest mb-2 block">{p.data.category}</span>
                  }
                  <h3 class="text-sm font-bold leading-snug flex-1 group-hover:text-white transition-colors">{p.data.title}</h3>
                  <p class="card-date text-xs text-slate-500 mt-4 pt-3 border-t border-white/10">{fmt(p.data.date)}</p>
                </div>
                <div class="card-arrow absolute bottom-4 right-4 z-20 w-8 h-8 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center">
                  <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                    <path d="M2 12L12 2M12 2H5M12 2V9" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <div class="card-img absolute bottom-0 left-0 right-0" style="height: 60%;">
                  <div class="card-img-fade"></div>
                  <img
                    src={p.data.cover}
                    alt={p.data.title}
                    class="w-full h-full object-cover"
                    style={`object-position: ${p.data.coverPosition ?? 'center'}`}
                  />
                </div>
              </a>
            ))}
          </div>
        )}

        <p id="sem-resultados" class="hidden text-center text-slate-400 py-16">Nenhuma matéria encontrada nessa categoria.</p>
      </div>
    )}

  </section>
</BaseLayout>

<style is:global>
  .select-wrapper { position: relative; display: inline-flex; align-items: center; }
  .select-wrapper select {
    appearance: none; -webkit-appearance: none;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    color: #e2e8f0; font-size: 0.875rem; font-weight: 500;
    font-family: 'Inter', sans-serif;
    padding: 0.6rem 2.5rem 0.6rem 1rem;
    border-radius: 9999px; cursor: pointer; outline: none;
    transition: border-color 0.2s, background 0.2s; min-width: 190px;
  }
  .select-wrapper select:hover,
  .select-wrapper select:focus { border-color: rgba(59,130,246,0.5); background: rgba(59,130,246,0.08); }
  .select-wrapper select option { background: #111827; color: #e2e8f0; }
  .select-arrow { position: absolute; right: 0.85rem; pointer-events: none; color: #94a3b8; display: flex; align-items: center; }

  /* Fade in da imagem */
  .card-img {
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 5;
  }
  .post-card:hover .card-img { opacity: 1; }

  /* Gradiente de blend no topo da imagem */
  .card-img-fade {
    position: absolute;
    top: 0; left: 0; right: 0; height: 4rem;
    background: linear-gradient(to bottom, #0B0F19 0%, transparent 100%);
    z-index: 6; pointer-events: none;
  }

  /* Data some no hover */
  .card-date { transition: opacity 0.25s ease; }
  .post-card:hover .card-date { opacity: 0; }

  /* Seta aparece no hover */
  .card-arrow { opacity: 0; transition: opacity 0.3s ease; }
  .post-card:hover .card-arrow { opacity: 1; }
</style>

<script is:inline>
  const select = document.getElementById('filtro-cat');
  const cards = document.querySelectorAll('.post-card');
  const blocoDestaque = document.getElementById('bloco-destaque');
  const sem = document.getElementById('sem-resultados');
  if (select) {
    select.addEventListener('change', () => {
      const cat = select.value;
      let visible = 0;
      cards.forEach((c) => {
        const match = cat === 'all' || c.getAttribute('data-cat') === cat;
        c.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (blocoDestaque) {
        const anyVisible = [...blocoDestaque.querySelectorAll('.post-card')].some(c => c.style.display !== 'none');
        blocoDestaque.style.display = anyVisible ? '' : 'none';
      }
      if (sem) sem.classList.toggle('hidden', visible > 0);
    });
  }
</script>
