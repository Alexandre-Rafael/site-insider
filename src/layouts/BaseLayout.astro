---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const SITE = 'https://insider-khaki.vercel.app';

interface Props {
  title: string;
  description?: string;
  cover?: string;
  current?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Estratégias de marketing digital que geram vendas reais em Patos de Minas e região.',
  cover = '/assets/bg.jpg',
  current,
  type = 'website',
  publishedTime,
  articleAuthor,
  articleSection,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE).href;
const ogImage = cover.startsWith('http') ? cover : `${SITE}${cover}`;
---
<!DOCTYPE html>
<html class="dark" lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>{title}</title>
  <link rel="canonical" href={canonicalURL} />
  <meta name="description" content={description} />
  {noindex
    ? <meta name="robots" content="noindex,nofollow" />
    : <meta name="robots" content="index,follow" />
  }

  <!-- Open Graph -->
  <meta property="og:site_name" content="Insider Mídia" />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="pt_BR" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {articleAuthor && <meta property="article:author" content={articleAuthor} />}
  {articleSection && <meta property="article:section" content={articleSection} />}

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Slot para scripts adicionais no <head> (ex: JSON-LD) -->
  <slot name="head" />

  <script is:inline src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
  <script is:inline define:vars={{}}>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#3B82F6",
            "primary-dark": "#1D4ED8",
            "primary-light": "#60A5FA",
            "background-light": "#F8FAFC",
            "background-dark": "#0B0F19",
            "surface-dark": "#111827",
            "surface-light": "#FFFFFF",
            "border-dark": "#1F2937",
            "border-light": "#E2E8F0",
          },
          fontFamily: { display: ["Inter", "sans-serif"], body: ["Inter", "sans-serif"] },
          borderRadius: { DEFAULT: "1rem", xl: "1.5rem", "2xl": "2rem" },
        },
      },
    };
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    .glass-card {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
    }
    .glow-effect { box-shadow: 0 0 30px rgba(59, 130, 246, 0.3); }
    .prose-insider :where(h2) { color: #fff; font-weight: 700; font-size: 1.6rem; margin-top: 2.5rem; margin-bottom: 0.75rem; line-height: 1.3; }
    .prose-insider :where(h3) { color: #fff; font-weight: 700; font-size: 1.25rem; margin-top: 2rem; margin-bottom: 0.5rem; line-height: 1.4; }
    .prose-insider :where(h4) { color: #fff; font-weight: 600; font-size: 1.05rem; margin-top: 1.5rem; margin-bottom: 0.5rem; }
    .prose-insider :where(p) { color: #cbd5e1; line-height: 1.85; margin-bottom: 1.25rem; }
    .prose-insider :where(a) { color: #60A5FA; text-decoration: underline; }
    .prose-insider :where(strong) { color: #fff; font-weight: 600; }
    .prose-insider :where(em) { color: #e2e8f0; }
    .prose-insider :where(blockquote) {
      border-left: 4px solid #3B82F6;
      padding: 0.75rem 1rem;
      color: #94a3b8;
      font-style: italic;
      margin: 2rem 0;
      background: rgba(59,130,246,0.06);
      border-radius: 0 8px 8px 0;
    }
    .prose-insider :where(img) { border-radius: 12px; margin: 2rem auto; max-width: 100%; display: block; }
    .prose-insider :where(ul) { list-style: disc; padding-left: 1.5rem; margin: 1rem 0 1.5rem; }
    .prose-insider :where(ol) { list-style: decimal; padding-left: 1.5rem; margin: 1rem 0 1.5rem; }
    .prose-insider :where(li) { color: #cbd5e1; line-height: 1.8; margin-bottom: 0.35rem; }
    .prose-insider :where(li > ul, li > ol) { margin: 0.25rem 0; }
    .prose-insider :where(hr) { border-color: rgba(255,255,255,0.1); margin: 2.5rem 0; }
    .prose-insider :where(code) { background: rgba(255,255,255,0.08); padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.875rem; color: #e2e8f0; }
    .prose-insider :where(pre) { background: #1e2535; padding: 1.25rem; border-radius: 10px; overflow-x: auto; margin: 1.5rem 0; }
    .prose-insider :where(pre code) { background: none; padding: 0; }
  </style>
</head>
<body class="bg-background-dark text-white antialiased">
  <Header current={current} />
  <main class="pt-20">
    <slot />
  </main>
  <Footer />
</body>
</html>
