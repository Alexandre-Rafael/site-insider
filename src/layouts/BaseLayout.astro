---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const SITE = 'https://insider-khaki.vercel.app';

interface Props {
  title: string;
  description?: string;
  cover?: string;
  current?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Estratégias de marketing digital que geram vendas reais em Patos de Minas e região.',
  cover = '/assets/bg.jpg',
  current,
  type = 'website',
  publishedTime,
  articleAuthor,
  articleSection,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE).href;
const ogImage = cover.startsWith('http') ? cover : `${SITE}${cover}`;
---
<!DOCTYPE html>
<html class="dark" lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>{title}</title>
  <link rel="canonical" href={canonicalURL} />
  <meta name="description" content={description} />
  {noindex
    ? <meta name="robots" content="noindex,nofollow" />
    : <meta name="robots" content="index,follow" />
  }

  <!-- Open Graph -->
  <meta property="og:site_name" content="Insider Mídia" />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="pt_BR" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {articleAuthor && <meta property="article:author" content={articleAuthor} />}
  {articleSection && <meta property="article:section" content={articleSection} />}

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Slot para scripts adicionais no <head> (ex: JSON-LD) -->
  <slot name="head" />

  <script is:inline src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
  <script is:inline define:vars={{}}>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#3B82F6",
            "primary-dark": "#1D4ED8",
            "primary-light": "#60A5FA",
            "background-light": "#F8FAFC",
            "background-dark": "#0B0F19",
            "surface-dark": "#111827",
            "surface-light": "#FFFFFF",
            "border-dark": "#1F2937",
            "border-light": "#E2E8F0",
          },
          fontFamily: { display: ["Inter", "sans-serif"], body: ["Inter", "sans-serif"] },
          borderRadius: { DEFAULT: "1rem", xl: "1.5rem", "2xl": "2rem" },
        },
      },
    };
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <style is:global>
    body { font-family: 'Inter', sans-serif; }
    .glass-card {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
    }
    .glow-effect { box-shadow: 0 0 30px rgba(59, 130, 246, 0.3); }

    /* Prose do blog — is:global para atingir o markdown renderizado */
    .prose-insider h2 { color: #60A5FA !important; font-weight: 700 !important; font-size: 1.55rem !important; margin-top: 2.5rem !important; margin-bottom: 0.75rem !important; line-height: 1.3 !important; }
    .prose-insider h3 { color: #93C5FD !important; font-weight: 700 !important; font-size: 1.2rem !important; margin-top: 2rem !important; margin-bottom: 0.5rem !important; line-height: 1.4 !important; }
    .prose-insider h4 { color: #BFDBFE !important; font-weight: 600 !important; font-size: 1.05rem !important; margin-top: 1.5rem !important; margin-bottom: 0.5rem !important; }
    .prose-insider p { color: #cbd5e1 !important; line-height: 1.85 !important; margin-bottom: 1.25rem !important; }
    .prose-insider a { color: #60A5FA !important; text-decoration: underline !important; }
    .prose-insider strong { color: #fff !important; font-weight: 600 !important; }
    .prose-insider em { color: #e2e8f0 !important; }
    .prose-insider blockquote {
      border-left: 4px solid #3B82F6 !important;
      padding: 0.75rem 1rem !important;
      color: #94a3b8 !important;
      font-style: italic !important;
      margin: 2rem 0 !important;
      background: rgba(59,130,246,0.06) !important;
      border-radius: 0 8px 8px 0 !important;
    }
    .prose-insider img { border-radius: 10px !important; margin: 2rem auto !important; max-width: 100% !important; display: block !important; }
    .prose-insider ul { list-style: disc !important; padding-left: 1.5rem !important; margin: 1rem 0 1.5rem !important; }
    .prose-insider ol { list-style: decimal !important; padding-left: 1.5rem !important; margin: 1rem 0 1.5rem !important; }
    .prose-insider li { color: #cbd5e1 !important; line-height: 1.8 !important; margin-bottom: 0.35rem !important; }
    .prose-insider li > ul, .prose-insider li > ol { margin: 0.25rem 0 !important; }
    .prose-insider hr { border-color: rgba(255,255,255,0.1) !important; margin: 2.5rem 0 !important; }
    .prose-insider code { background: rgba(255,255,255,0.08) !important; padding: 0.15rem 0.4rem !important; border-radius: 4px !important; font-size: 0.875rem !important; color: #e2e8f0 !important; }
    .prose-insider pre { background: #1e2535 !important; padding: 1.25rem !important; border-radius: 10px !important; overflow-x: auto !important; margin: 1.5rem 0 !important; }
    .prose-insider pre code { background: none !important; padding: 0 !important; }
  </style>
</head>
<body class="bg-background-dark text-white antialiased">
  <Header current={current} />
  <main class="pt-20">
    <slot />
  </main>
  <Footer />
</body>
</html>
